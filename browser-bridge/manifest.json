{
  "manifest_version": 3,
  "name": "APW Chrome Bridge",
  "description": "Connect the APW daemon to Apple's PasswordManagerBrowserExtensionHelper through Chrome native messaging.",
  "version": "2.0.0",
  "minimum_chrome_version": "120",
  "key": "",
  "permissions": [
    "nativeMessaging",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "APW Bridge",
    "default_popup": "popup.html"
  }
}
